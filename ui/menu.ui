  <property name="styleSheet">
   <string notr="true">
QMainWindow { background-color: #020c1e; }
QWidget#centralwidget { background-color: transparent; }
QLabel#labelBg { background-color: transparent; }
QPushButton#btnConfiguration {
    background-color: rgba(255,255,255,100); font: 75 11pt &quot;MS Shell Dlg 2&quot;;
    color: white; font-size: 20px; border-radius: 10px; padding: 8px 15px; text-align: left;
}
QPushButton#btnConfiguration:hover { background-color: rgba(255,255,255,180); }
QPushButton#btnConfiguration:pressed { background-color: rgba(255,255,255,220); }
QPushButton#btnConfiguration:checked {
    background-color: rgba(0,160,255,180); color: white; border: 1px solid rgba(0,220,255,200);
}
QPushButton#btnLaneLKA {
    background-color: rgba(255,255,255,100); font: 75 11pt &quot;MS Shell Dlg 2&quot;;
    color: white; font-size: 20px; border-radius: 10px; padding: 8px 15px; text-align: left;
}
QPushButton#btnLaneLKA:hover { background-color: rgba(255,255,255,180); }
QPushButton#btnLaneLKA:pressed { background-color: rgba(255,255,255,220); }
QPushButton#btnLaneLKA:checked {
    background-color: rgba(0,200,120,180); color: white; border: 1px solid rgba(0,255,150,200);
}
QPushButton#btnStart {
    background-color: rgba(255,255,255,100); font: 75 11pt &quot;MS Shell Dlg 2&quot;;
    color: white; font-size: 20px; border-radius: 10px; padding: 8px 15px; text-align: left;
}
QPushButton#btnStart:hover { background-color: rgba(255,255,255,180); }
QPushButton#btnStart:pressed { background-color: rgba(255,255,255,220); }
QPushButton#btnCardConfigHardware, QPushButton#btnCardConfigProgram, QPushButton#btnCardStart {
    background-color: rgba(255,255,255,100); font: 75 11pt &quot;MS Shell Dlg 2&quot;;
    color: white; font-size: 18px; border-radius: 10px; padding: 8px 12px; text-align: left;
}
QPushButton#btnCardConfigHardware:hover, QPushButton#btnCardConfigProgram:hover, QPushButton#btnCardStart:hover { background-color: rgba(255,255,255,180); }
QPushButton#btnCardConfigHardware:pressed, QPushButton#btnCardConfigProgram:pressed, QPushButton#btnCardStart:pressed { background-color: rgba(255,255,255,220); }

QStatusBar {
    background-color: rgba(0,5,20,240); color: rgba(0,180,255,150);
    font-family: &quot;MS Shell Dlg 2&quot;; font-size: 10px; border-top: 1px solid rgba(0,180,255,60);
}
QScrollArea { background: transparent; border: none; }
QScrollArea &gt; QWidget &gt; QWidget { background: transparent; }
QScrollBar:vertical {
    background: rgba(255,255,255,20); width: 6px; border-radius: 3px; margin: 0px;
}
QScrollBar::handle:vertical {
    background: rgba(0,180,255,150); border-radius: 3px; min-height: 24px;
}
QScrollBar::handle:vertical:hover { background: rgba(0,180,255,220); }
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical { height: 0px; }
QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical { background: none; }
